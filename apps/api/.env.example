# ---- Loyalty OS API configuration ----
NODE_ENV=development
PORT=4000

# Public base URL of this API (used to build QR redirect links)
API_BASE_URL=http://localhost:4000

# Public base URL of the customer web app (QR scans redirect here)
WEB_BASE_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# Auth
JWT_SECRET=dev-super-secret-change-me
JWT_EXPIRES_IN=7d

# Database. SQLite by default for zero-config local dev.
# For production swap to Postgres, e.g. postgresql://user:pass@host:5432/loyalty
DATABASE_URL="file:./dev.db"

# OTP delivery. In dev, OTPs are returned in the API response + logged.
OTP_TTL_SECONDS=300
OTP_DEV_ECHO=true
