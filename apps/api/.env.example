# ---- Rewrd API configuration. Copy to .env and fill in. ----
NODE_ENV=development
PORT=4000

# Public base URL of this API
API_BASE_URL=http://localhost:4000
# Public base URL of the customer web app (QR codes encode this — set to your real domain in prod)
WEB_BASE_URL=http://localhost:3000
# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# ---- Auth ----
JWT_SECRET=change-me-generate-a-random-64-char-string
JWT_EXPIRES_IN=7d
CUSTOMER_JWT_EXPIRES_IN=180d   # returning customers stay logged in; email OTP only on 1st scan

# ---- Database ----
# Dev SQLite: file:./dev.db  (also flip datasource provider to "sqlite")
# Prod Postgres (Neon/Supabase/RDS):
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# ---- OTP (email-only — no SMS/WhatsApp provider) ----
OTP_TTL_SECONDS=300
OTP_DEV_ECHO=true            # true = return code in API response (dev only). Set false in prod.
TRIAL_DAYS=30                # free-trial length (merchant "1 month free" model)

# ---- Google Sign-In (auto-login). OAuth 2.0 Web Client ID from Google Cloud Console. ----
GOOGLE_CLIENT_ID=

# ---- Email (Resend — free tier 3,000/mo). Delivers customer OTP codes + reminders. ----
RESEND_API_KEY=
EMAIL_FROM=Rewrd <onboarding@resend.dev>

# ---- Web Push (VAPID). Generate: node -e "console.log(require('web-push').generateVAPIDKeys())" ----
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@rewrd.online

# ---- Google Maps (reverse-geocode for GPS branch detection; optional) ----
GOOGLE_MAPS_API_KEY=

# ---- Sentry (error monitoring; optional) ----
SENTRY_DSN=

# Note: payments are handled offline (UPI) with operator-managed access —
# no payment-gateway keys required. Suspend/terminate is in the admin console.

# ---- Platform operator login (the ONLY superadmin). Set your own private values. ----
ADMIN_EMAIL=admin@rewrd.dev
ADMIN_PASSWORD=admin1234
