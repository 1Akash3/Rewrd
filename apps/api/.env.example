# ---- Loyalty OS API configuration ----
NODE_ENV=development
PORT=4000

# Public base URL of this API (used to build QR redirect links)
API_BASE_URL=http://localhost:4000

# Public base URL of the customer web app (QR scans redirect here)
WEB_BASE_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# Auth
JWT_SECRET=dev-super-secret-change-me
JWT_EXPIRES_IN=7d

# Database. SQLite by default for zero-config local dev.
# For production swap to Postgres, e.g. postgresql://user:pass@host:5432/loyalty
DATABASE_URL="file:./dev.db"

# OTP delivery. In dev, OTPs are returned in the API response + logged.
OTP_TTL_SECONDS=300
OTP_DEV_ECHO=true

# Free-trial length in days (merchant "1 month free, then subscribe" model).
TRIAL_DAYS=30

# ===========================================================================
# PRODUCTION KEYS — leave blank in dev (features degrade to safe stubs).
# Fill these in when going live. See docs/PRODUCTION-CHECKLIST.md.
# ===========================================================================

# --- SMS / WhatsApp OTP delivery (replaces the dev on-screen echo) ---
# India: MSG91 or Gupshup. Global: Twilio. Set OTP_DEV_ECHO=false in prod.
OTP_PROVIDER=            # msg91 | twilio | gupshup
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# --- Payments / subscriptions (Razorpay recommended for India) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Stripe alternative:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Redis (OTP store, rate limits, queues) ---
REDIS_URL=              # e.g. rediss://default:pass@host:6379

# --- Object storage for QR posters & media (S3 or Cloudflare R2) ---
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=

# --- Email (invoices, reminders) ---
RESEND_API_KEY=
EMAIL_FROM=

# --- PWA push notifications (generate with: npx web-push generate-vapid-keys) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Google Maps (reverse-geocode for GPS branch detection; optional) ---
GOOGLE_MAPS_API_KEY=

# --- Error monitoring (optional) ---
SENTRY_DSN=
