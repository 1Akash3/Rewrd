# Copy to .env.local and fill in. .env.local is gitignored.

# Where /api/* requests are proxied (the Express API). See next.config.mjs.
API_PROXY_TARGET=http://localhost:4000

# Google OAuth 2.0 Web Client ID (must match the API's GOOGLE_CLIENT_ID).
# Exposed to the browser for Google Identity Services — safe to be public.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
